# Supabase (from Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Database (from Project Settings → Database → Connection string URI)
# Replace [YOUR-PASSWORD] with your project database password
DATABASE_URL=

# Beta: encrypt Kalshi private keys at rest (min 32 chars). Required in production.
CREDENTIAL_ENCRYPTION_KEY=

# Public app URL for invite links (e.g. https://app.compd.trade or Railway URL)
NEXT_PUBLIC_APP_URL=

# Admin panel (Basic Auth). Set in production.
ADMIN_USERNAME=
ADMIN_PASSWORD=
